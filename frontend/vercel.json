{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-render-url.onrender.com/api/:path*"
    },
    {
      "source": "/sanctum/:path*",
      "destination": "https://your-backend-render-url.onrender.com/sanctum/:path*"
    },
    {
      "source": "/(?!api|sanctum)(.*)",
      "destination": "/index.html"
    }
  ]
}
